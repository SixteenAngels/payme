VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Enable Google OAuth in Supabase Dashboard -> Authentication -> Providers -> Google.
# Add your site URL and redirect URL (e.g. http://localhost:5173 and your production domain).

# Set these as Supabase Edge Function secrets, not Vite/browser env vars.
MOOLRE_BASE_URL=https://sandbox.moolre.com
MOOLRE_API_USER=your-moolre-username
MOOLRE_API_KEY=your-moolre-private-key
MOOLRE_ACCOUNT_NUMBER=your-moolre-account-number
MOOLRE_CURRENCY=GHS
MOOLRE_DEFAULT_CHANNEL=1
MOOLRE_BANK_SUBLIST_ID=optional-bank-id
